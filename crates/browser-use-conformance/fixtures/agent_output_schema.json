        "print_background": {
          "default": true,
          "type": "boolean"
        },
        "scale": {
          "default": 1.0,
          "format": "double",
          "type": "number"
        }
      },
      "type": "object"
    },
    "ScreenshotAction": {
      "properties": {
        "file_name": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
