    "ScrollAction": {
      "properties": {
        "down": {
          "default": true,
          "type": "boolean"
        },
        "index": {
          "format": "uint32",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "pages": {
          "default": 1.0,
          "format": "double",
          "type": "number"
        }
      },
      "type": "object"
    },
    "SearchAction": {
      "properties": {
        "engine": {
          "allOf": [
            {
              "$ref": "#/definitions/SearchEngine"
            }
          ],
          "default": "duckduckgo"
        },
        "query": {
          "type": "string"
        }
      },
      "required": [
        "query"
      ],
      "type": "object"
    },
    "SearchEngine": {
      "enum": [
        "duckduckgo",
        "google",
        "bing"
      ],
      "type": "string"
    },
    "SearchPageAction": {
      "description": "Text or regex search against page content.",
      "properties": {
        "case_sensitive": {
          "default": false,
          "type": "boolean"
        },
        "context_chars": {
          "default": 150,
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        },
        "css_scope": {
          "type": [
            "string",
            "null"
          ]
        },
        "max_results": {
          "default": 25,
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        },
        "pattern": {
          "type": "string"
        },
        "regex": {
          "default": false,
          "type": "boolean"
        }
      },
      "required": [
        "pattern"
      ],
      "type": "object"
