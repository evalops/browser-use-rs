    "SelectDropdownOptionAction": {
      "properties": {
        "index": {
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        },
        "text": {
          "type": "string"
        }
      },
      "required": [
        "index",
        "text"
      ],
      "type": "object"
    },
    "SendKeysAction": {
      "properties": {
