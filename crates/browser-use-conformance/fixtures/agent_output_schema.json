    "ReadFileAction": {
      "properties": {
        "file_name": {
          "type": "string"
        }
      },
      "required": [
        "file_name"
      ],
      "type": "object"
    },
    "ReplaceFileAction": {
      "properties": {
        "file_name": {
          "type": "string"
        },
        "new_str": {
          "type": "string"
