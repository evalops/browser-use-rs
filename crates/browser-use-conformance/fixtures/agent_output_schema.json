    "ClickElementAction": {
      "properties": {
        "coordinate_x": {
          "format": "int32",
          "type": [
            "integer",
            "null"
          ]
        },
        "coordinate_y": {
          "format": "int32",
          "type": [
            "integer",
            "null"
          ]
        },
        "index": {
          "format": "uint32",
          "minimum": 1.0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "CloseTabAction": {
      "properties": {
        "tab_id": {
          "maxLength": 4,
          "minLength": 4,
          "type": "string"
