        "content": {
          "type": "string"
        },
        "file_name": {
          "type": "string"
        },
        "leading_newline": {
          "default": false,
          "type": "boolean"
        },
        "trailing_newline": {
          "default": true,
          "type": "boolean"
        }
      },
      "required": [
        "content",
        "file_name"
      ],
      "type": "object"
    }
  },
  "properties": {
    "action": {
      "items": {
        "$ref": "#/definitions/BrowserAction"
      },
      "minItems": 1,
      "type": "array"
    },
    "current_plan_item": {
      "format": "uint",
      "minimum": 0.0,
      "type": [
        "integer",
        "null"
      ]
    },
    "evaluation_previous_goal": {
      "type": [
        "string",
        "null"
      ]
    },
    "memory": {
      "type": [
        "string",
        "null"
      ]
    },
    "next_goal": {
      "type": [
        "string",
        "null"
      ]
    },
    "plan_update": {
      "items": {
        "type": "string"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "thinking": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "evaluation_previous_goal",
    "memory",
    "next_goal",
    "action"
  ],
  "title": "AgentOutput",
  "type": "object"
}
