      "properties": {
        "seconds": {
          "default": 3,
          "format": "int64",
          "type": "integer"
        }
      },
      "type": "object"
    },
    "WriteFileAction": {
      "properties": {
        "append": {
          "default": false,
          "type": "boolean"
