      "required": [
        "tab_id"
      ],
      "type": "object"
    },
    "UploadFileAction": {
      "properties": {
        "index": {
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "index",
        "path"
      ],
      "type": "object"
    },
